<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Ignore requests to the API folder so PHP scripts execute normally
  RewriteCond %{REQUEST_URI} ^/api/ [NC]
  RewriteRule ^ - [L]

  # If an existing asset or directory is requested, go to it
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  
  # Otherwise, redirect everything else to index.html for React Router
  RewriteRule ^ index.html [QSA,L]
</IfModule>
